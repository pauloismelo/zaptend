# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://zaptend:password@localhost:5432/zaptend_dev

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=change-this-super-secret-jwt-key-at-least-32-chars
JWT_REFRESH_SECRET=change-this-super-secret-refresh-key-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Meta / WhatsApp Cloud API
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v20.0

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_S3_BUCKET=zaptend-media-dev
AWS_KMS_KEY_ARN=arn:aws:kms:sa-east-1:123456789:key/...
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────
# Anthropic (AI Engine)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
WORKER_PORT=3002

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
